{
  "info": {
    "name": "BrightSmile Dental API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Complete API collection for BrightSmile Dental. Set the {{base_url}} variable to http://localhost:8080 and {{token}} to the JWT returned by /api/auth/login."
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "token",    "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"5551234567\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json(); if(r.accessToken) pm.collectionVariables.set('token', r.accessToken);"] } }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@brightsmile.com\",\n  \"password\": \"Admin@1234\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "url": "{{base_url}}/api/auth/logout" }
        },
        {
          "name": "Verify Email",
          "request": { "method": "GET", "url": "{{base_url}}/api/auth/verify?token=YOUR_TOKEN_HERE" }
        }
      ]
    },
    {
      "name": "Public — Services",
      "item": [
        {
          "name": "List All Services",
          "request": { "method": "GET", "url": "{{base_url}}/api/services" }
        },
        {
          "name": "Get Service by ID",
          "request": { "method": "GET", "url": "{{base_url}}/api/services/1" }
        }
      ]
    },
    {
      "name": "Public — Slots",
      "item": [
        {
          "name": "Get Available Slots",
          "request": { "method": "GET", "url": "{{base_url}}/api/slots?date=2026-06-10&doctorId=1" }
        }
      ]
    },
    {
      "name": "Public — Book Appointment",
      "item": [
        {
          "name": "Book (Guest)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/appointments",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"serviceId\": 1,\n  \"doctorId\": 1,\n  \"startDatetime\": \"2026-06-10T09:00:00\",\n  \"guestName\": \"John Guest\",\n  \"guestEmail\": \"john@guest.com\",\n  \"guestPhone\": \"5551234567\",\n  \"notes\": \"First visit\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Public — Contact",
      "item": [
        {
          "name": "Submit Contact Form",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/contact",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Sarah Jones\",\n  \"email\": \"sarah@example.com\",\n  \"phone\": \"5559876543\",\n  \"message\": \"I'd like to know more about your teeth whitening services.\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Patient Portal",
      "item": [
        {
          "name": "My Appointments",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/portal/appointments",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Cancel Appointment",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/portal/appointments/1/cancel",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Admin — Dashboard",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/admin/dashboard/stats",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Admin — Appointments",
      "item": [
        {
          "name": "List (paginated, filterable)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/admin/appointments?page=0&size=20&status=PENDING",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get One",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/admin/appointments/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Status",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/admin/appointments/1/status?status=CONFIRMED",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/admin/appointments/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Admin — Patients",
      "item": [
        {
          "name": "List",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/admin/patients?page=0&size=20",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get One",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/admin/patients/2",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/admin/patients/2",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Admin — Services",
      "item": [
        {
          "name": "List All",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/admin/services",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/admin/services",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Teeth Polishing\",\n  \"description\": \"Professional polish for a brighter smile.\",\n  \"category\": \"PREVENTIVE\",\n  \"durationMin\": 30,\n  \"price\": 80.00,\n  \"visible\": true,\n  \"sortOrder\": 7\n}" }
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/admin/services/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Dental Cleaning\",\n  \"description\": \"Updated description.\",\n  \"category\": \"PREVENTIVE\",\n  \"durationMin\": 60,\n  \"price\": 130.00,\n  \"visible\": true,\n  \"sortOrder\": 1\n}" }
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/admin/services/7",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Admin — Team",
      "item": [
        {
          "name": "List",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/admin/team",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Add Doctor",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/admin/team",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Dr. Emily Clark\",\n  \"email\": \"emily@brightsmile.com\",\n  \"password\": \"Doctor@123\",\n  \"phone\": \"5550000001\",\n  \"specialty\": \"Cosmetic Dentistry\",\n  \"bio\": \"Expert in veneers and whitening.\",\n  \"credentials\": \"DDS, Harvard\",\n  \"visible\": true\n}" }
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/admin/team/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Admin — Schedule",
      "item": [
        {
          "name": "Get Doctor Schedule",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/admin/schedule/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Set Doctor Schedule",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/admin/schedule/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "[\n  { \"dayOfWeek\": \"MONDAY\",    \"startTime\": \"09:00\", \"endTime\": \"17:00\", \"slotDurationMin\": 30 },\n  { \"dayOfWeek\": \"TUESDAY\",   \"startTime\": \"09:00\", \"endTime\": \"17:00\", \"slotDurationMin\": 30 },\n  { \"dayOfWeek\": \"WEDNESDAY\", \"startTime\": \"09:00\", \"endTime\": \"17:00\", \"slotDurationMin\": 30 },\n  { \"dayOfWeek\": \"THURSDAY\",  \"startTime\": \"09:00\", \"endTime\": \"17:00\", \"slotDurationMin\": 30 },\n  { \"dayOfWeek\": \"FRIDAY\",    \"startTime\": \"09:00\", \"endTime\": \"14:00\", \"slotDurationMin\": 30 }\n]" }
          }
        },
        {
          "name": "Block Time Slot",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/admin/schedule/block",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"doctorId\": 1,\n  \"startDatetime\": \"2026-06-15T12:00:00\",\n  \"endDatetime\": \"2026-06-15T13:00:00\",\n  \"reason\": \"Lunch break\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Admin — Settings",
      "item": [
        {
          "name": "Get Settings",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/admin/settings",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Settings",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/admin/settings",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"clinic.name\": \"BrightSmile Dental\",\n  \"clinic.phone\": \"(555) 123-4567\",\n  \"clinic.email\": \"hello@brightsmile.com\",\n  \"notifications.reminder_24h\": \"true\",\n  \"notifications.reminder_2h\": \"true\"\n}" }
          }
        }
      ]
    }
  ]
}
